set -e

# Format staged files (prettier for JS/HTML/JSON/MD)
yarn lint-staged

# Verify generated Flatpak Cargo source list matches Cargo.lock when dependency files change
if git diff --cached --name-only -- \
  src-tauri/Cargo.toml \
  src-tauri/Cargo.lock \
  packaging/flatpak/cargo-sources.json \
  packaging/flatpak/generate-cargo-sources.sh | grep -q .; then
  packaging/flatpak/generate-cargo-sources.sh --check
  if ! git diff --quiet -- packaging/flatpak/cargo-sources.json; then
    echo "packaging/flatpak/cargo-sources.json has unstaged changes; stage it with git add before committing." >&2
    exit 1
  fi
fi

# Run Rust linting (format check + clippy)
cd src-tauri && cargo fmt --check && cargo clippy --all-targets --all-features -- -D warnings
